#  START 
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.message.from_user.id

    if is_blocked(user_id):
        await update.message.reply_text("You are blocked.")
        return

    users.add(user_id)
    save_users()

    global last_accounts_count

    if last_accounts_count == 0:
        await update.message.reply_text("No accounts available.")
        return

    if user_id in user_orders:
        await update.message.reply_text(
            "You already have an ongoing order. Please wait until it is approved or rejected."
        )
        return

    username = update.message.from_user.username
    username = f"@{username}" if username else str(user_id)

    msg = await update.message.reply_text(
        f"Welcome! {username}\n"
        f"Available stock: {last_accounts_count}\n"
        f"Price per item = {PRICE_PER_ITEM}$\n"
        f"Discount price = 1.3$ for 10+ items\n\n"
        f"Please send the quantity you need."
    )

    user_orders[user_id] = {"message_id": msg.message_id}
    save_orders()


# ===== BLOCK =====
async def block_user(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.message.from_user.id != ADMIN_ID:
        await update.message.reply_text("You cannot use this command.")
        return

    if not context.args:
        await update.message.reply_text("Usage:\n/block USER_ID")
        return

    try:
        user_id = int(context.args[0])
    except:
        await update.message.reply_text("Invalid user ID.")
        return

    blocked_users.add(user_id)
    save_blocked_users()

    user_orders.pop(user_id, None)
    locked_users.pop(user_id, None)

    if user_id in countdown_tasks:
        countdown_tasks[user_id].cancel()
        countdown_tasks.pop(user_id, None)

    await update.message.reply_text(f"User {user_id} has been blocked.")

    try:
        await context.bot.send_message(user_id, "You have been blocked by admin.")
    except:
        pass


#  COUNTDOWN 
async def countdown_timer(context, user_id, message, total_price, quantity):
    remaining = LOCK_TIME

    while remaining > 0:
        minutes = remaining // 60
        seconds = remaining % 60

        new_text = (
            build_addresses_text() +
            f"Total price: {total_price}$\n"
            f"Quantity: {quantity}\n"
            f"Remaining time: {minutes:02d}:{seconds:02d}\n"
            f"Please send the payment receipt."
        )

        try:
            await message.edit_text(new_text, parse_mode="Markdown")
        except:
            pass

        await asyncio.sleep(1)
        remaining -= 1

    try:
        await message.edit_text("Time expired. You can place a new order.")
    except:
        pass

    locked_users.pop(user_id, None)
    user_orders.pop(user_id, None)
    save_orders()
    countdown_tasks.pop(user_id, None)


#  RECEIPT 
async def receive_receipt(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.message.from_user.id

    if user_id not in user_orders or "quantity" not in user_orders[user_id]:
        await update.message.reply_text("No ongoing order.")
        return

    if time.time() > locked_users.get(user_id, 0):
        user_orders.pop(user_id, None)
        locked_users.pop(user_id, None)
        save_orders()
        await update.message.reply_text("Time expired.")
        return

    if user_orders[user_id].get("receipt_sent"):
        await update.message.reply_text("Receipt already sent. Waiting for admin review.")
        return

    user_orders[user_id]["receipt_sent"] = True
    save_orders()

    if user_id in countdown_tasks:
        countdown_tasks[user_id].cancel()
        countdown_tasks.pop(user_id, None)

    message_id = user_orders[user_id].get("payment_message_id")
    if message_id:
        try:
            await context.bot.edit_message_text(
                chat_id=user_id,
                message_id=message_id,
                text="Order sent for review."
            )
        except:
            pass

    quantity = user_orders[user_id]["quantity"]

    keyboard = [[
        InlineKeyboardButton("Approve", callback_data=f"approve_{user_id}"),
        InlineKeyboardButton("Reject", callback_data=f"reject_{user_id}")
    ]]

    username = update.message.from_user.username
    username = f"@{username}" if username else str(user_id)

    await context.bot.send_photo(
        chat_id=ADMIN_ID,
        photo=update.message.photo[-1].file_id,
        caption=f"New order\nUser: {username}\nID: {user_id}\nQuantity: {quantity}",
        reply_markup=InlineKeyboardMarkup(keyboard)
    )


#  UNBLOCK 
async def unblock_user(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.message.from_user.id != ADMIN_ID:
        await update.message.reply_text("You cannot use this command.")
        return

    if not context.args:
        await update.message.reply_text("Usage:\n/unblock USER_ID")
        return

    try:
        user_id = int(context.args[0])
    except:
        await update.message.reply_text("Invalid user ID.")
        return

    if user_id in blocked_users:
        blocked_users.remove(user_id)
        save_blocked_users()

    user_orders.pop(user_id, None)
    save_orders()

    if user_id in countdown_tasks:
        countdown_tasks[user_id].cancel()
        countdown_tasks.pop(user_id, None)

    locked_users.pop(user_id, None)

    await update.message.reply_text(f"User {user_id} has been unblocked.")

    try:
        await context.bot.send_message(user_id, "You have been unblocked by admin.")
    except:
        pass
